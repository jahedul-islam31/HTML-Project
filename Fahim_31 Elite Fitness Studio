        .nav-link {
            position: relative;
        }
        .nav-link::after {
            content: '';
            position: absolute; bottom: -2px; left: 0;
            width: 0; height: 1px;
            background: #FF4D00;
            transition: width 0.3s ease;
        }
        .nav-link:hover::after { width: 100%; }

        .marquee-track {
            display: flex;
            animation: marquee 30s linear infinite;
        }
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
